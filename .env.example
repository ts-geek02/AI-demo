# AI provider API keys — copy this file to .env and fill in the key for your chosen provider.
# The active provider is set in ai.config.json ("provider" field).

# Grok (xAI) — https://console.x.ai/
XAI_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Set to 1 to skip AI test generation for a single push (e.g. in CI)
# SKIP_AI_TESTS=1
